# Intel Engine: Firecrawl + Nemotron
# Get key at https://firecrawl.dev
FIRECRAWL_API_KEY=
# Get key at https://build.nvidia.com
NVIDIA_API_KEY=
BACKEND_BASE_URL=http://localhost:8000

# Deployment pipeline: GitHub (required for DIRECT_CODE)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=owner/repo

# Vercel (required after merge for deployment polling)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_PROJECT_ID=your_vercel_project_id_here

# Slack (required for SLACK_MESSAGE)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Optional: auto-merge PRs when true (default false). Can also toggle via PATCH /agent/dangerous-mode
DANGEROUS_MODE=false
